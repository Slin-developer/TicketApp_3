# Frontend (Vite) env. Only VITE_-prefixed vars are bundled into the browser.
# NEVER put the Stripe SECRET key or the Supabase service-role key here — see
# RULES.md Rule 7. The Stripe secret belongs only in supabase/functions/.env.
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=
VITE_STRIPE_PUBLISHABLE_KEY=
