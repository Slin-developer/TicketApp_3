# Edge Function secrets (gitignored locally; `supabase secrets set ...` in prod).
# SUPABASE_URL / SUPABASE_SERVICE_ROLE_KEY are auto-injected in deployed
# functions; set them here only for local `supabase functions serve`.
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# Stripe. Use sk_test_ for dev; swap to sk_live_ in Supabase secrets for prod.
# STRIPE_WEBHOOK_SECRET comes from `stripe listen` (whsec_...) locally, or the
# Stripe Dashboard webhook endpoint's signing secret in prod.
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# Optional. STRIPE_CURRENCY defaults to eur. APP_URL is the frontend origin used
# for Checkout success/cancel redirects (falls back to the request origin).
# PLATFORM_FEE_BPS applies an application fee on Connect charges (basis points).
STRIPE_CURRENCY=eur
APP_URL=
PLATFORM_FEE_BPS=0
